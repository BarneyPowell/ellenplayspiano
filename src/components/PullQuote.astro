---
import { pullQuote } from "../data/site";
---

<div class="pull-quote animate-on-scroll">
  <blockquote>"{pullQuote.text}"</blockquote>
  <cite>— {pullQuote.attribution}</cite>
</div>

<style>
  .pull-quote {
    max-width: 650px;
    margin: 0 auto;
    padding: 5rem 4rem;
    text-align: center;
  }

  blockquote {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    font-style: italic;
    color: var(--cream);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  cite {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-style: normal;
    color: var(--gold-muted);
    letter-spacing: 0.03em;
  }

  @media (max-width: 768px) {
    .pull-quote {
      padding: 3.5rem 1.5rem;
    }
  }
</style>
